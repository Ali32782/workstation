# =========================================================================
# Multi-vertical Prospecting Scraper (MedTheris + Kineo)
# Copy to .env, fill values, never commit .env.
#
# The scraper supports three profiles, each with its own CRM target:
#   * physio        → Twenty workspace MEDTHERIS  (uses TWENTY_API_KEY)
#   * aerzte        → Twenty workspace KINEO      (uses TWENTY_KINEO_API_KEY)
#   * sportvereine  → Twenty workspace KINEO      (uses TWENTY_KINEO_API_KEY)
# Both workspaces live on the SAME Twenty server (TWENTY_API_URL).
# =========================================================================

# --- Google Maps Places API ---
# Get a key at https://console.cloud.google.com/apis/library/places-backend.googleapis.com
# Required scopes/APIs to enable:
#   - Places API
#   - Places API (New) is OPTIONAL — this scraper uses the legacy Places API
# Pricing: $200 free credit/month (covers ~17.000 Place Details requests).
# Restrict the key to "Places API" + your IP for safety.
GOOGLE_MAPS_API_KEY=

# --- Twenty CRM (MedTheris workspace) ---
# IMPORTANT: this scraper writes leads for the MedTheris tenant, so its
# API key MUST be issued from the MedTheris workspace inside Twenty —
# NOT from the Kineo360 workspace, otherwise every lead lands in the
# wrong tenant and shows up under /kineo/crm in the portal.
#
# How to get the right key:
#   1. Open https://crm.kineo360.work, sign in as a workspace admin and
#      switch the workspace selector to "MedTheris".
#   2. Settings → Developers → API Keys → "+ Create API Key"
#      → "MedTheris Scraper".
#   3. Copy the JWT into TWENTY_API_KEY below.
#
# On the prod server, this is already provisioned as
# TWENTY_WORKSPACE_MEDTHERIS_TOKEN in /opt/corelab/.env — reuse that
# value here when running the scraper from a server-side cron.
# Server origin only (GraphQL: {TWENTY_API_URL}/graphql). Do not append /api.
TWENTY_API_URL=https://crm.kineo360.work
TWENTY_API_KEY=

# --- Twenty CRM (Kineo workspace) — for the aerzte + sportvereine profiles ---
# Issue a separate API key from the KINEO workspace in Twenty:
#   Settings → Developers → API Keys → "+ Create API Key" → "Kineo Scraper".
# On the prod server this is provisioned as TWENTY_WORKSPACE_KINEO_TOKEN in
# /opt/corelab/.env — reuse that value here.
# Leave empty if you only run the physio profile; main.py refuses to push
# kineo-targeted runs without it (clear error message).
TWENTY_KINEO_API_KEY=

# --- Anthropic API ---
# Used for structured extraction from practice websites (owner name, employee
# count, specializations etc.) via Claude.
# Get a key at https://console.anthropic.com → Settings → API Keys.
ANTHROPIC_API_KEY=

# --- Tenant tag override (optional) ---
# Each profile carries its own default tenant tag (medtheris / kineo) — the
# value below only acts as a manual override when set. Leave empty in
# normal multi-profile operation, otherwise the override applies to ALL
# profiles in the same process.
# TENANT_TAG=medtheris

# --- Default profile (optional) ---
# When the CLI is invoked without --profile, this is what main.py picks.
# Defaults to "physio" for backwards compatibility with Medtheris cron jobs.
# SCRAPER_DEFAULT_PROFILE=physio

# --- Owner-LinkedIn lookup via Claude web_search (OPT-IN) ---
# When set to "1", scraper will ask Claude to use its built-in web_search
# tool to locate the owner's LinkedIn profile (and optionally the practice's
# LinkedIn company page) for every practice where:
#   * an owner_name was extracted, AND
#   * the website did not already link to a personal LinkedIn page.
# Cost: ~$0.03 per practice on Sonnet 4.5 — i.e. ~$30 per 1k leads. Off by
# default so a normal Discovery sweep stays cheap; enable for a one-shot
# enrichment run after the first sweep.
ENABLE_SOCIAL_LOOKUP=0

# --- Anthropic model override (optional) ---
# Defaults to claude-sonnet-4-5-20250929 in extractor.py / social_finder.py.
# Override only if you need to fall back to an older model for cost reasons.
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
