# =========================================================================
# Corehub / MedTheris - Self-Hosted Stack
# Copy to .env and fill. NEVER commit .env.
# Generate secrets: `openssl rand -base64 32` or `pwgen -s 32 1`
# =========================================================================

# --- Global ---
TZ=Europe/Zurich
# Corehub internal (dev team)
PUBLIC_DOMAIN_COREHUB=corehub.io
# Kineo360 - product platform. Every tenant (incl. MedTheris internal) lives
# as <tenant>.kineo360.work with services at <service>.<tenant>.kineo360.work
PUBLIC_DOMAIN_KINEO=kineo360.work
# MedTheris - company mail domain only (if ever needed for branded mailboxes)
PUBLIC_DOMAIN_MEDTHERIS=medtheris.com
ACME_EMAIL=ali.peters@kineo.swiss

# --- Keycloak ---
# KC_HOSTNAME is the canonical URL. The same container also answers on
# auth.medtheris.kineo360.work and every auth.<slug>.kineo360.work thanks to
# KC_HOSTNAME_STRICT=false + per-realm frontendUrl. Master admin is reachable
# via auth.kineo360.work (operator/dev).
KC_HOSTNAME=auth.kineo360.work
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_STRONG
KC_DB_PASSWORD=CHANGE_ME_STRONG

# --- Rocket.Chat ---
ROCKETCHAT_URL=https://chat.kineo360.work
ROCKETCHAT_MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG
# Shared secret for Rocket.Chat Outgoing Webhook → portal call-ring (token query or X-Rocketchat-Token header).
ROCKETCHAT_CALL_RING_WEBHOOK_SECRET=

# --- Nextcloud Corehub ---
NC_COREHUB_URL=files.kineo360.work
NC_COREHUB_ADMIN_USER=admin
NC_COREHUB_ADMIN_PASSWORD=CHANGE_ME_STRONG
NC_COREHUB_DB_PASSWORD=CHANGE_ME_STRONG

# --- Nextcloud MedTheris (internal team — tenant 'medtheris' on Kineo360) ---
NC_MEDTHERIS_URL=files.medtheris.kineo360.work
NC_MEDTHERIS_ADMIN_USER=admin
NC_MEDTHERIS_ADMIN_PASSWORD=CHANGE_ME_STRONG
NC_MEDTHERIS_DB_PASSWORD=CHANGE_ME_STRONG

# --- MariaDB (shared by Nextcloud + Mautic) ---
MARIADB_ROOT_PASSWORD=CHANGE_ME_STRONG

# --- Mautic (Marketing Automation, MedTheris-Tenant) ---
# Reachable at marketing.medtheris.kineo360.work via NPM. Three containers:
# mautic_web (HTTP), mautic_cron (scheduled jobs), mautic_worker (queues).
# DB user/db is auto-provisioned by scripts/mariadb-init.sh on first boot.
# Initial admin user is created interactively on first /mautic visit
# (set credentials there, then commit them to your password manager).
MAUTIC_URL=https://marketing.medtheris.kineo360.work
MAUTIC_DB_NAME=mautic
MAUTIC_DB_USER=mautic
MAUTIC_DB_PASSWORD=CHANGE_ME_STRONG
# API token (Bearer) so the portal & Twenty CRM can sync contacts/segments.
# Generate after install: Mautic UI → Settings → API Credentials → New token.
MAUTIC_API_TOKEN=
MAUTIC_API_USERNAME=
MAUTIC_INTERNAL_URL=http://mautic_web
# Default Mautic segment id for the admin Lead-Inbox "Approve → Funnel" action.
# When set, approving a scraper lead pushes the company's people into this
# segment without an extra dropdown choice. Leave empty to force the operator
# to pick a segment per approval (UI dropdown).
MAUTIC_DEFAULT_SCRAPER_SEGMENT_ID=

# --- Collabora ---
COLLABORA_URL=office.kineo360.work
# Regex of allowed Nextcloud hosts. Covers the operator apex (files.kineo360.work)
# and every tenant (files.<slug>.kineo360.work) via the wildcard subdomain.
COLLABORA_ALLOWED_HOSTS="files\\.kineo360\\.work|files\\..+\\.kineo360\\.work"

# --- Twenty CRM ---
TWENTY_URL=https://crm.kineo360.work
# Optional: Helpdesk „CRM“-Link zur Person. Platzhalter {{id}} = Twenty-UUID.
# Standard ohne diese Zeile: {TWENTY_URL}/object/person/{id}
# TWENTY_PERSON_URL_TEMPLATE=https://crm.kineo360.work/object/person/{{id}}
TWENTY_INTERNAL_URL=http://twenty:3000
TWENTY_APP_SECRET=CHANGE_ME_STRONG
TWENTY_PG_PASSWORD=CHANGE_ME_STRONG
# Multi-tenant Twenty mapping. One Twenty instance, multiple workspaces; each
# portal workspace points at a separate Twenty workspace + workspace-scoped JWT.
#
# Provisioning a new tenant (programmatic — no UI walk required):
#   1. POST /metadata `signUp(email, password)` → workspace-agnostic token
#   2. UPDATE core."user" SET "canAccessFullAdminPanel"=true,"isEmailVerified"=true
#      WHERE email='<bridge-user-email>'  (Twenty restricts workspace creation to
#      server admins when IS_MULTIWORKSPACE_ENABLED=true, which we keep on so the
#      mutation is reachable in the first place — see docker-compose.yml).
#   3. POST /metadata `signIn` → loginToken for the now-existing workspace
#   4. POST /metadata `getAuthTokensFromLoginToken` → workspace ACCESS token
#   5. POST /metadata `signUpInNewWorkspace` (if not yet) →  workspaceId
#   6. POST /metadata `activateWorkspace(displayName)` to leave PENDING_CREATION
#   7. POST /metadata `createApiKey` + `generateApiKeyToken` → long-lived JWT
#   8. UPDATE core.workspace SET subdomain=<slug>, "displayName"=<Label>
# Leave a pair empty to disable native CRM for that portal workspace (the UI
# falls back to a "noch nicht eingerichtet" empty state instead of crashing).
TWENTY_WORKSPACE_KINEO_ID=CHANGE_ME_UUID
TWENTY_WORKSPACE_KINEO_TOKEN=CHANGE_ME_JWT
TWENTY_WORKSPACE_MEDTHERIS_ID=
TWENTY_WORKSPACE_MEDTHERIS_TOKEN=
TWENTY_WORKSPACE_COREHUB_ID=
TWENTY_WORKSPACE_COREHUB_TOKEN=
CRM_ALLOWED_GROUPS=/kineo/,/medtheris/,/corehub/
# Twenty SMTP — Migadu mailbox johannes@medtheris.kineo360.work (Sales sender).
# Use port 465 + SECURE=true (Migadu's preferred submission for cloud apps —
# port 587/STARTTLS works too but Twenty's nodemailer wrapper is reliable on 465).
TWENTY_SMTP_FROM_ADDRESS=johannes@medtheris.kineo360.work
TWENTY_SMTP_FROM_NAME=Kineo360 CRM
TWENTY_SMTP_HOST=smtp.migadu.com
TWENTY_SMTP_PORT=465
TWENTY_SMTP_USER=johannes@medtheris.kineo360.work
TWENTY_SMTP_PASSWORD=CHANGE_ME_MIGADU_PASSWORD

# --- Gitea ---
GITEA_URL=https://git.kineo360.work
GITEA_DB_PASSWORD=CHANGE_ME_STRONG
GITEA_INTERNAL_URL=http://gitea:3000
GITEA_BRIDGE_TOKEN=changeme
CODE_ALLOWED_GROUPS=/kineo/,/medtheris/,/corehub/

# --- Portainer ---
# Portainer is reachable only via SSH tunnel: ssh -L 9000:localhost:9000 server

# --- Portal (Corehub Workstation, Next.js shell at app.kineo360.work) ---
PORTAL_URL=https://app.kineo360.work
# Generate: openssl rand -base64 32
PORTAL_AUTH_SECRET=CHANGE_ME_STRONG
# Keycloak client (realm `main`; anlegen mit scripts/migrate-to-main-realm.sh — Secret mit scripts/keycloak-portal-client.sh --print-secret)
PORTAL_KC_CLIENT_ID=portal
PORTAL_KC_CLIENT_SECRET=CHANGE_ME_AFTER_KC_CLIENT_CREATION
# Embeddable Lead-Form → POST /api/public/lead (Bearer or JSON `token`).
# Generate: openssl rand -base64 32
PUBLIC_LEAD_FORM_SECRET=
# Portal workspace slug (`kineo`, `medtheris`, …) when the client omits `workspace` in JSON.
PUBLIC_LEAD_DEFAULT_WORKSPACE=kineo
# Same workspace is used by the public page `/p/lead` (Server Action → CRM).
# Comma-separated origins allowed to call the endpoint from a browser (CORS). Same-origin as POST URL always allowed.
LEAD_FORM_ALLOWED_ORIGINS=

# --- Kineo workspace · External embeds (optional — leave blank to hide in sidebar) ---
# Public HTTPS URLs (NPM Proxy Hosts). NPM must inject frame-ancestors for https://app.kineo360.work
# (see scripts/npm-iframe-csp.sh). Streamlit/chatbot frameworks often block iframes unless
# the app's CSP / X-Frame-Options is relaxed at the upstream — see docs/kineo-reporting-integration.md.
# Each *_URL has an optional *_EMBED=newtab|iframe override (default: iframe). Set newtab for
# tools that refuse to be embedded.
# NEXT_PUBLIC_KINEO_GAP_REPORT_URL=https://gap-report.kineo360.work
# NEXT_PUBLIC_KINEO_GAP_REPORT_EMBED=iframe
# NEXT_PUBLIC_KINEO_OPERATIONS_DASHBOARD_URL=https://dashboard.kineo360.work
# NEXT_PUBLIC_KINEO_OPERATIONS_DASHBOARD_EMBED=iframe
# Self-hosted Streamlit dashboard — see docs/kineo-dashboard-setup.md.
# Bind-mounts /opt/corelab/kineo-dashboard/{input,output} so xlsx exports survive rebuilds.
# NEXT_PUBLIC_KINEO_CHATBOT_URL=https://bot.kineo360.work
# NEXT_PUBLIC_KINEO_CHATBOT_EMBED=iframe
# Self-hosted bot replaces kineo-raumplanungsassistent.onrender.com — see docs/kineo-bot-setup.md.
# Bot reuses SCRAPER_ANTHROPIC_API_KEY by default; set BOT_ANTHROPIC_API_KEY for a separate key.
# BOT_ANTHROPIC_API_KEY=
# BOT_DATABASE_URL=
# BOT_APP_TOKEN=
# BOT_SLOTS_API_KEY=

# --- Integration event feed + Pulse (Phase 1 slice) ---
# Documenso sends DOCUMENT_* JSON + header X-Documenso-Secret — must match DOCUMENSO_WEBHOOK_SECRET.
# Generic JSON (e.g. Zammad bridge): POST { "workspaceId", "eventType", "payload" } with Bearer INTEGRATION_FEED_WEBHOOK_SECRET.
# DOCUMENSO_WEBHOOK_SECRET=
# INTEGRATION_FEED_WEBHOOK_SECRET=
# INTEGRATION_FEED_DEFAULT_WORKSPACE=corehub
# INTEGRATION_FEED_ROCKETCHAT_CHANNEL=#integrations

# --- Documenso (sign.kineo360.work) ---
DOCUMENSO_URL=https://sign.kineo360.work
# Generate: openssl rand -base64 32 | tr -d '/+=' | head -c 40   (each one separately!)
DOCUMENSO_NEXTAUTH_SECRET=CHANGE_ME_STRONG
DOCUMENSO_ENCRYPTION_KEY=CHANGE_ME_STRONG
DOCUMENSO_ENCRYPTION_SECONDARY_KEY=CHANGE_ME_STRONG
DOCUMENSO_DB_PASSWORD=CHANGE_ME_STRONG
# PKCS#12 cert passphrase (generate with: openssl rand -base64 24 | tr -d '/+=' | head -c 28)
DOCUMENSO_SIGNING_PASSPHRASE=CHANGE_ME_STRONG
# Keycloak OIDC client secret (must match what's set in Keycloak `main` realm,
# client_id=documenso). Configure in Keycloak Admin UI for realm `main` (see docs/oidc-wiring.md); no dedicated repo script yet.
DOCUMENSO_KC_CLIENT_SECRET=CHANGE_ME_AFTER_KC_CLIENT_CREATION
DOCUMENSO_OIDC_LABEL=Kineo360 SSO
# SMTP (Migadu). Prefer a mailbox on the **active** Migadu domain `kineo360.work`
# while subdomains like `medtheris.kineo360.work` are still pending DNS verification.
DOCUMENSO_SMTP_USERNAME=johannes@kineo360.work
DOCUMENSO_SMTP_PASSWORD=CHANGE_ME_MIGADU_PASSWORD
DOCUMENSO_SMTP_FROM_NAME=Kineo360 Sign
DOCUMENSO_SMTP_FROM_ADDRESS=johannes@kineo360.work
# Alternate (after medtheris.* is Active in Migadu): use johannes@medtheris.kineo360.work for USER + FROM.
# Set to "true" once all members are SSO-provisioned (locks down public signup form).
DOCUMENSO_DISABLE_PUBLIC_SIGNUP=false

# Per-workspace Documenso teams (consumed by the native portal /sign UI).
# A single bridge user (`portal-bridge@kineo360.work`) owns the Kineo360
# Documenso organisation and is admin of three teams (one per workspace).
# Each team has its own bearer-style API token; the portal selects the
# right token from the workspace param so tenants are isolated server-side.
#
# Two ways to provision:
#   1. Set the values below in /opt/corelab/.env and restart the portal.
#   2. Provision via the admin UI: /admin/onboarding/sign — paste the team
#      token and the portal persists it in the `portal_data` Docker volume
#      under /data/sign-tenants.json. ENV always wins over the runtime
#      store, so this only kicks in when the corresponding *_TOKEN below
#      is empty.
#
DOCUMENSO_TEAM_COREHUB_TOKEN=
DOCUMENSO_TEAM_COREHUB_URL=corehub
DOCUMENSO_TEAM_MEDTHERIS_TOKEN=
DOCUMENSO_TEAM_MEDTHERIS_URL=medtheris
DOCUMENSO_TEAM_KINEO_TOKEN=
DOCUMENSO_TEAM_KINEO_URL=kineo
# Portal: who may see "In Documenso verwalten" (must also be in PORTAL_ADMIN_USERNAMES). Default: ali
SIGN_DOCUMENSO_NATIVE_USERNAMES=ali

# --- Jitsi (docker-compose.jitsi.yml) ---
# Shared Jitsi, operated by MedTheris, consumed by all practices
JITSI_DOMAIN=meet.medtheris.kineo360.work
JITSI_PUBLIC_URL=https://meet.medtheris.kineo360.work
# Portal iframe: HTTPS-URL zu JSON für Jitsi Dynamic Branding (euer Logo; siehe Jitsi-Handbuch „brandingDataUrl“).
# Ohne eigene meet-Instanz-Anpassung können einzelne Jitsi-Elemente weiter sichtbar sein (Whitelist).
# NEXT_PUBLIC_JITSI_BRANDING_DATA_URL=https://app.example.com/branding/jitsi-branding.json
JICOFO_COMPONENT_SECRET=CHANGE_ME_STRONG
JICOFO_AUTH_PASSWORD=CHANGE_ME_STRONG
JVB_AUTH_PASSWORD=CHANGE_ME_STRONG
# Public IP of the Hetzner host (required so JVB advertises reachable endpoint)
DOCKER_HOST_ADDRESS=xxx.xxx.xxx.xxx

# --- Zammad (docker-compose.zammad.yml) ---
ZAMMAD_URL=https://support.medtheris.kineo360.work
ZAMMAD_INTERNAL_URL=http://zammad-nginx:8080
ZAMMAD_BRIDGE_TOKEN=changeme
HELPDESK_ALLOWED_GROUPS=/kineo/,/medtheris/,/corehub/
# Multi-tenant Helpdesk: one Zammad instance, but each portal workspace owns
# one or more Zammad Groups. Tickets outside a tenant's groups are invisible
# (and unmodifiable) to that tenant.
# Names are matched case-insensitively against Zammad group names.
HELPDESK_TENANT_MEDTHERIS_GROUPS=Medtheris Support
# Must match real Zammad group name(s). If unset or empty, /kineo/helpdesk shows „not configured“.
HELPDESK_TENANT_KINEO_GROUPS=Kineo Internal
HELPDESK_TENANT_COREHUB_GROUPS=

# --- Phonestar → Helpdesk (Zammad) ---
# In Phonestar Kundenportal: Webhook URL (POST JSON):
#   https://app.kineo360.work/api/integrations/phonestar/webhook?token=<secret>
# Events: channel_create | channel_answer | channel_destroy (inbound + outbound)
PHONESTAR_WEBHOOK_SECRET=
# Portal-Workspace-ID, dessen HELPDESK_TENANT_*_GROUPS die Tickets erhalten:
PHONESTAR_HELPDESK_WORKSPACE=kineo
# Offenes Ticket mit gleichem Titel wird für Answer/Destroy bis N Minuten gesucht:
PHONESTAR_TICKET_WINDOW_MIN=240

# --- MedTheris-Scraper (docker-compose: medtheris-scraper) ---
# TWENTY_API_URL im Container kommt aus SCRAPER_TWENTY_API_URL — nur Origin, nie …/api
# (sonst GraphQL 404 auf …/api/graphql). Leer lassen = Default https://crm.kineo360.work
# SCRAPER_TWENTY_API_URL=https://crm.kineo360.work
# SCRAPER_TWENTY_API_KEY=<Twenty JWT aus MedTheris-Workspace>
# Optional: Anthropic web_search Fallback um eine Praxis-Website zu finden,
# wenn Google Maps keine listet (~$0.03 / Lead). Default 0 = aus, damit Cron-
# Discovery-Läufe kein LLM-Budget verbrennen. Für manuelle --retry-no-website
# Läufe über den bestehenden Cache auf 1 setzen (siehe docs/scraper-runner.md).
# SCRAPER_ENABLE_WEBSITE_LOOKUP=0

# --- SMTP (Migadu) ---
# Used by Rocket.Chat, Nextcloud, Keycloak, Twenty for outgoing mail.
# Hetzner blocks port 25 outbound; Migadu's IPv6 is unreachable (server is
# IPv4-only). USE port 587 + STARTTLS. Failed auth attempts trigger a hard
# rate-limit ('421 too many errors') for 30-60 min — be careful with retries.
SMTP_HOST=smtp.migadu.com
SMTP_PORT=587
SMTP_USER=noreply@kineo360.work
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM_EMAIL=noreply@kineo360.work
SMTP_FROM_NAME=Kineo360

# --- DNS / TLS ---
# kineo360.work DNS lives on Cloudflare (Multi-level wildcards + DNS-01).
# corehub.io and medtheris.com stay on Vercel.
# The Cloudflare API token is NOT stored in .env — NPM keeps it internally.
# Create it at https://dash.cloudflare.com/profile/api-tokens (Edit zone DNS
# scoped to kineo360.work) and paste into NPM's Let's Encrypt DNS challenge.
# See docs/dns-setup.md for the full flow.

# --- Backups (Hetzner Object Storage, S3-compatible) ---
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_BUCKET=kineo360-backups
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
BACKUP_RETENTION_DAYS=30

# --- OpenCut (in-browser video editor, CapCut alternative) ---
# Stack: docker-compose.opencut.yml (separate compose, own Postgres + Redis).
# Docs:  docs/opencut-setup.md
# OPENCUT_PUBLIC_URL=https://videos.kineo360.work
# OPENCUT_BETTER_AUTH_SECRET=$(openssl rand -hex 32)
# OPENCUT_DB_PASSWORD=$(openssl rand -base64 24 | tr -d /=+)
# OPENCUT_REDIS_HTTP_TOKEN=$(openssl rand -hex 16)
# Optional sound library + blog CMS keys — leave empty to disable:
# OPENCUT_FREESOUND_CLIENT_ID=
# OPENCUT_FREESOUND_API_KEY=
# OPENCUT_MARBLE_WORKSPACE_KEY=
# Portal-side: makes the Marketing-Workspace sidebar app appear (NEXT_PUBLIC_*
# is baked at build time, so set this BEFORE rebuilding `portal`).
# NEXT_PUBLIC_OPENCUT_URL=https://videos.kineo360.work

# --- Postiz (open-source social-media manager, Buffer/Hootsuite alternative) ---
# Stack: docker-compose.postiz.yml (separate compose, own Postgres + Redis).
# Docs:  docs/postiz-setup.md
# POSTIZ_PUBLIC_URL=https://social.kineo360.work
# POSTIZ_FRONTEND_URL=https://social.kineo360.work
# POSTIZ_NEXT_PUBLIC_BACKEND_URL=https://social.kineo360.work/api
# POSTIZ_BACKEND_INTERNAL_URL=http://postiz_backend:3000
# POSTIZ_JWT_SECRET=$(openssl rand -hex 32)
# POSTIZ_DB_PASSWORD=$(openssl rand -base64 24 | tr -d /=+)
# Per-platform OAuth (set the ones you actually use; leave others empty):
# POSTIZ_X_API_KEY=
# POSTIZ_X_API_SECRET=
# POSTIZ_LINKEDIN_CLIENT_ID=
# POSTIZ_LINKEDIN_CLIENT_SECRET=
# POSTIZ_FACEBOOK_APP_ID=
# POSTIZ_FACEBOOK_APP_SECRET=
# POSTIZ_INSTAGRAM_APP_ID=
# POSTIZ_INSTAGRAM_APP_SECRET=
# POSTIZ_TIKTOK_CLIENT_ID=
# POSTIZ_TIKTOK_CLIENT_SECRET=
# POSTIZ_YOUTUBE_CLIENT_ID=
# POSTIZ_YOUTUBE_CLIENT_SECRET=
# Optional AI-Copilot:
# POSTIZ_OPENAI_API_KEY=
# Portal-side: NEXT_PUBLIC_* is baked at build time.
# NEXT_PUBLIC_POSTIZ_URL=https://social.kineo360.work
