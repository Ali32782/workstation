{
  "name": "portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:i18n:verbose": "node scripts/check-i18n.mjs --verbose",
    "lint": "eslint --quiet src",
    "lint:fix": "eslint --fix src",
    "typecheck": "tsc --noEmit",
    "verify": "npm run check:i18n && npm run typecheck && npm run lint",
    "smoke": "playwright test",
    "smoke:install": "playwright install chromium --with-deps",
    "smoke:headed": "playwright test --headed"
